# Rosé Pine
# Base colors
# background: #191724
# foreground: #e0def4
# black: #26233a
# red: #eb6f92
# green: #9ccfd8
# yellow: #f6c177
# blue: #31748f
# magenta: #c4a7e7
# cyan: #ebbcba
# white: #e0def4

# Directory
DIR 01;34
# Link
LINK 01;36
# Socket
SOCK 01;35
# Pipe
PIPE 40;33
# Block
BLK 40;33;01
# Char
CHR 40;33;01
# Executable
EXEC 01;32

# Mapping to Rosé Pine colors (using ANSI codes)
# red: 31 (eb6f92)
# green: 32 (9ccfd8)
# yellow: 33 (f6c177)
# blue: 34 (31748f)
# magenta: 35 (c4a7e7)
# cyan: 36 (ebbcba)

DIR 01;34
LINK 01;36
FIFO 40;33
SOCK 01;35
BLK 40;33;01
CHR 40;33;01
EXEC 01;32
